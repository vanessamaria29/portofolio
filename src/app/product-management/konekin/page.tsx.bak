            8. RICE PRIORITIZATION
            ========================================= */}
        <FadeIn direction="up">
          <SlideFrame index="08" title="RICE Prioritization">
            <div className="mb-6">
              <p className="text-sm text-slate-600 bg-slate-50 p-4 rounded-lg border border-slate-200">
                <span className="font-bold text-slate-800">Why RICE?</span> Framework ini digunakan untuk menentukan prioritas MVP berdasarkan dampak terhadap pengguna, tingkat keyakinan, jangkauan pengguna, dan effort pengembangan.
              </p>
            </div>

            <div className="overflow-x-auto rounded-xl border border-slate-200">
              <table className="w-full text-left border-collapse text-xs md:text-sm text-slate-700 min-w-[600px]">
                <thead>
                  <tr className="bg-slate-100/80 border-b border-slate-200 text-slate-800">
                    <th className="p-4 font-bold">Feature</th>
                    <th className="p-4 font-bold text-center">Reach</th>
                    <th className="p-4 font-bold text-center">Impact</th>
                    <th className="p-4 font-bold text-center">Confidence</th>
                    <th className="p-4 font-bold text-center">Effort</th>
                    <th className="p-4 font-bold text-center text-blue-700">RICE Score</th>
                  </tr>
                </thead>
                <tbody className="divide-y divide-slate-100">
                  {[
                    { feat: "Project Matching", r: 9, i: 3, c: 90, e: 3 },
                    { feat: "Skill Profile", r: 9, i: 2, c: 95, e: 2 },
                    { feat: "In App Chat", r: 8, i: 3, c: 80, e: 3 },
                    { feat: "Portfolio & Review", r: 7, i: 2, c: 85, e: 2 }
                  ].map((item, idx) => {
                    const score = ((item.r * item.i * (item.c/100)) / item.e).toFixed(1);
                    return (
                      <tr key={idx} className="hover:bg-slate-50/50 transition-colors">
                        <td className="p-4 font-semibold text-slate-800">{item.feat}</td>
                        <td className="p-4 text-center font-medium">{item.r}</td>
                        <td className="p-4 text-center font-medium">{item.i}</td>
                        <td className="p-4 text-center font-medium">{item.c}%</td>
                        <td className="p-4 text-center font-medium">{item.e}</td>
                        <td className="p-4 text-center font-bold text-blue-700 text-base bg-blue-50/30">{score}</td>
                      </tr>
                    )
                  })}
                </tbody>
              </table>
            </div>
          </SlideFrame>
        </FadeIn>

        {/* =========================================
            9. SOLUTION
            ========================================= */}
        <FadeIn direction="up">
          <SlideFrame index="09" title="Proposed Solutions">
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
              {[
                { title: "Smart Matching", desc: "Mencocokkan kebutuhan UMKM dengan kompetensi mahasiswa." },
                { title: "Project Marketplace", desc: "UMKM dapat mempublikasikan kebutuhan proyek." },
                { title: "Portfolio", desc: "Mahasiswa dapat membangun rekam jejak pengalaman." },
                { title: "Review & Rating", desc: "Meningkatkan kepercayaan kedua belah pihak." }
              ].map((feature, idx) => (
                <div key={idx} className="bg-white/80 border border-slate-200 p-6 rounded-xl shadow-sm transform transition-transform hover:-translate-y-2 hover:shadow-md flex flex-col">
                  <div className="w-12 h-12 rounded-lg bg-blue-100 text-blue-600 flex items-center justify-center mb-4 font-bold text-xl shadow-inner flex-shrink-0">
                    {idx + 1}
                  </div>
                  <h4 className="font-bold text-slate-900 text-base mb-2">{feature.title}</h4>
                  <p className="text-slate-600 text-sm leading-relaxed">{feature.desc}</p>
                </div>
              ))}
            </div>
          </SlideFrame>
        </FadeIn>

        {/* =========================================
            10. PROTOTYPE
            ========================================= */}
        <FadeIn direction="up">
          <div className="bg-white/60 backdrop-blur-md border border-slate-200/80 rounded-2xl p-6 md:p-10 shadow-sm relative overflow-hidden mb-12">
            <div className="border-b border-slate-200 pb-4 mb-8">
              <span className="text-[10px] md:text-xs font-semibold text-purple-600 tracking-wider uppercase">10 / PROTOTYPE</span>
              <h3 className="font-serif text-2xl font-bold text-slate-900 mt-1">Interactive Mockup</h3>
            </div>
            
            <div className="bg-slate-100 rounded-xl overflow-hidden shadow-inner border border-slate-200 flex flex-col items-center p-8">
               <img src="/images/onium-ui.png" alt="Konekin Interface" className="max-w-full h-auto rounded-lg shadow-xl" />
               <p className="text-xs text-slate-500 mt-6 text-center italic">*Branding KONEKIN UI concept (Placeholder)*</p>
            </div>
          </div>
        </FadeIn>

        {/* =========================================
            11. SUCCESS METRICS
            ========================================= */}
        <FadeIn direction="up">
          <SlideFrame index="11" title="Success Metrics">
            <div className="bg-gradient-to-r from-blue-600 to-indigo-600 rounded-xl p-8 shadow-md mb-8 text-white text-center transform transition-all hover:scale-[1.02]">
              <span className="inline-block px-3 py-1 bg-white/20 text-white text-[10px] font-bold uppercase tracking-widest rounded-full mb-3">
                North Star Metric
              </span>
              <h4 className="text-xl md:text-2xl font-bold leading-tight">
                Jumlah kolaborasi UMKM dan mahasiswa yang berhasil diselesaikan melalui KONEKIN.
              </h4>
            </div>

            <div className="grid grid-cols-2 md:grid-cols-5 gap-4">
              {[
                "Match Success Rate",
                "Project Completion Rate",
                "Active Users",
                "Repeat Collaboration Rate",
                "User Satisfaction Score"
              ].map((metric, idx) => (
                <div key={idx} className="bg-slate-50 border border-slate-200 p-4 rounded-lg flex flex-col items-center justify-center text-center gap-2 hover:bg-white hover:border-blue-200 hover:shadow-sm transition-all">
                  <ShieldCheck className="w-6 h-6 text-blue-500 opacity-80" />
                  <span className="text-xs font-bold text-slate-700 leading-snug">{metric}</span>
                </div>
              ))}
            </div>
          </SlideFrame>
        </FadeIn>

        {/* =========================================
            12. PRODUCT ROADMAP
            ========================================= */}
        <FadeIn direction="up">
          <SlideFrame index="12" title="Product Roadmap">
            <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
              {[
                { phase: "Phase 1", title: "Matching Platform", active: true },
                { phase: "Phase 2", title: "Portfolio & Review", active: false },
                { phase: "Phase 3", title: "Community & Networking", active: false },
                { phase: "Phase 4", title: "AI Recommendation", active: false }
              ].map((item, idx) => (
                <div key={idx} className={`p-5 rounded-xl border ${item.active ? 'bg-blue-50 border-blue-200 shadow-sm' : 'bg-slate-50/50 border-slate-100'} relative`}>
                  {item.active && (
                     <span className="absolute top-4 right-4 flex h-3 w-3">
                       <span className="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
                       <span className="relative inline-flex rounded-full h-3 w-3 bg-blue-500"></span>
                     </span>
                  )}
                  <span className={`text-[10px] font-bold uppercase tracking-widest ${item.active ? 'text-blue-600' : 'text-slate-400'} block mb-2`}>
                    {item.phase}
                  </span>
                  <h4 className={`font-bold ${item.active ? 'text-slate-900' : 'text-slate-600'}`}>
                    {item.title}
                  </h4>
                </div>
              ))}
            </div>
          </SlideFrame>
        </FadeIn>

        {/* =========================================
            13. REFLECTION
            ========================================= */}
        <FadeIn direction="up">
          <SlideFrame index="13" title="Penutup & Pembelajaran">
            <div className="bg-white/80 border border-purple-200 p-8 rounded-xl shadow-sm relative overflow-hidden">
              <div className="absolute top-0 right-0 w-32 h-32 bg-purple-100 rounded-bl-full -z-10 opacity-50" />
              
              <div className="flex items-center gap-3 mb-6">
                <CheckCircle2 className="w-6 h-6 text-purple-600" />
                <h4 className="font-bold text-slate-900 text-lg">Yang Saya Pelajari</h4>
              </div>
              
              <p className="text-slate-700 leading-relaxed md:text-lg font-medium">
                Melalui proyek KONEKIN, saya belajar bahwa membangun platform dua sisi membutuhkan pemahaman yang seimbang terhadap kebutuhan seluruh stakeholder. 
                <br/><br/>
                Saya memperdalam kemampuan dalam menyusun <strong className="text-purple-800">strategi produk</strong>, memetakan <strong className="text-purple-800">stakeholder</strong>, menentukan prioritas fitur menggunakan framework <strong className="text-purple-800">RICE</strong>, serta merancang solusi yang mampu memberikan nilai nyata bagi UMKM maupun mahasiswa secara bersamaan.
              </p>
            </div>
          </SlideFrame>
        </FadeIn>

      </main>
    </div>
  );
}
